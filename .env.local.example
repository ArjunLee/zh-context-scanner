# zh-context-scanner LLM Configuration Example
# Copy this file to .env.local and fill in your API Key

# Universal Configuration (Recommended) - Supports all OpenAI-compatible services
LLM_API_KEY=sk-your-api-key-here
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# Auto-binding Control (Optional)
# By default, the tool auto-selects optimal model for each translation mode:
#   - COMMENT_ONLY -> deepseek-chat (fast, cheap, 8K output)
#   - FULL -> deepseek-reasoner (64K output for large files)
# Set LLM_FORCE_MODEL=true to disable auto-binding and always use LLM_MODEL
# LLM_FORCE_MODEL=false

# DeepSeek Specific
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# OpenAI Specific
# OPENAI_API_KEY=sk-your-openai-api-key

# Common Model Configuration (Uncomment and modify API Key to use)

# DeepSeek:
# LLM_API_KEY=sk-your-deepseek-key
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_FORCE_MODEL=false  # Auto-binding enabled (comment_only->chat, full->reasoner)

# OpenAI:
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com
# LLM_MODEL=gpt-4o
# LLM_FORCE_MODEL=true  # Force use gpt-4o for all modes

# Moonshot (Kimi):
# LLM_API_KEY=sk-your-moonshot-key
# LLM_BASE_URL=https://api.moonshot.cn
# LLM_MODEL=moonshot-v1-8k

# MiniMax:
# LLM_API_KEY=sk-your-minimax-key
# LLM_BASE_URL=https://api.minimax.chat
# LLM_MODEL=abab6.5s

# SiliconFlow:
# LLM_API_KEY=sk-your-siliconflow-key
# LLM_BASE_URL=https://api.siliconflow.cn
# LLM_MODEL=Pro/Qwen/Qwen2.5-72B-Instruct

# Azure OpenAI:
# LLM_API_KEY=your-azure-key
# LLM_BASE_URL=https://your-resource.openai.azure.com
# LLM_MODEL=gpt-4o

# Local LM Studio / Ollama:
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://localhost:1234  # LM Studio default port
# LLM_BASE_URL=http://localhost:11434  # Ollama default port
# LLM_MODEL=qwen3.5-9b
# LLM_FORCE_MODEL=true  # Force use local model

# Security Notice:
# - .env.local contains sensitive information and will not be tracked by Git
# - Rotate API Keys regularly
#
# Auto-binding Feature:
# - When LLM_FORCE_MODEL=false (default), the tool auto-selects optimal model:
#   - COMMENT_ONLY mode -> deepseek-chat (fast, cheap, 8K output limit)
#   - FULL mode -> deepseek-reasoner (64K output limit for large files)
# - When LLM_FORCE_MODEL=true, always use the model specified in LLM_MODEL
# - DeepSeek API base URL is https://api.deepseek.com (not /v1/chat/completions)

